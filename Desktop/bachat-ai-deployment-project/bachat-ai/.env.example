# ─────────────────────────────────────────────────────────────────────────────
# BachatAI — Environment Variables Reference
# Copy this file to the correct location and fill in real values.
# NEVER commit files with real credentials to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (.env inside frontend/) ─────────────────────────────────────────
# Used by Vite — VITE_ prefix is required for browser exposure
VITE_API_URL=https://bachatai-backend.onrender.com
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Backend (.env inside backend/) ───────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ML_API_URL=https://bachatai-ml-api.onrender.com
ALLOWED_ORIGINS=https://bachatai.vercel.app
FLASK_ENV=production

# ── ML API — no env vars needed ───────────────────────────────────────────────
# Models are loaded from committed files in ml/models/
# The Render service reads them directly from the git repo clone.
